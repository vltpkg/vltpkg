{
  "name": "vlt",
  "description": "The vlt CLI",
  "version": "0.0.0-1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vltpkg/vltpkg.git",
    "directory": "infra/cli"
  },
  "devDependencies": {
    "@vltpkg/infra-build": "workspace:*"
  },
  "license": "BSD-2-Clause-Patent",
  "engines": {
    "node": ">=22",
    "pnpm": "9"
  },
  "scripts": {
    "prepack": "vlt-build"
  },
  "type": "module",
  "keywords": [
    "vltpkg"
  ],
  "publishConfig": {
    "directory": "./.build-publish",
    "bin": {
      "vlt": "./vlt.js",
      "vlr": "./vlr.js",
      "vlx": "./vlx.js",
      "vlrx": "./vlrx.js",
      "vlix": "./vlix.js"
    }
  }
}
